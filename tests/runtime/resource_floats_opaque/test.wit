//@ dependencies = ['intermediate', 'leaf']
//@ wac = 'compose.wac'

package test:resource-floats-opaque;

// Re-exporter interface: constructor-only float. The runner imports it,
// the intermediate exports it, and the leaf provides the underlying
// implementation. The intermediate's constructor forwards an inner
// handle from the leaf as the exported rep verbatim — no Box, no deref.
interface chain {
  resource float {
    constructor(v: f64);
  }
}

world leaf {
  export chain;
}

// Opaque-rep stress fixture: deliberately omit methods. The pattern
// under test is *constructor forwarding* — a 3-component chain where
// intermediate's constructor builds an inner resource and returns the
// inner handle as the exported rep verbatim.
//   1. runner constructs a chain.float (calls into intermediate)
//   2. intermediate constructs a chain.float in leaf, returns its handle
//      verbatim as the rep (no Box, no deref)
//   3. runner drops the chain.float (calls intermediate's drop)
//
// Method forwarding (e.g. `get`) for opaque-rep resources requires
// deeper generator changes; this fixture exercises only the
// load-bearing constructor + drop path.
world intermediate {
  export chain;

  import imports-chain: interface {
    resource float {
      constructor(v: f64);
    }
  }
}

world runner {
  import chain;

  export run: func();
}
