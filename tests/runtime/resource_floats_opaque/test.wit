//@ dependencies = ['intermediate', 'leaf']
//@ wac = 'compose.wac'

package test:resource-floats-opaque;

// Re-exporter interface: constructor-only float. The runner imports it,
// the intermediate exports it, and the leaf provides the underlying
// implementation. The intermediate's constructor forwards an inner
// handle from the leaf as the exported rep verbatim — no Box, no deref.
interface chain {
  resource float {
    constructor(v: f64);
  }
}

world leaf {
  export chain;
}

// Opaque-rep stress fixture: deliberately omit methods. The pattern
// under test is *constructor forwarding* — a 3-component chain where
// intermediate's constructor builds an inner resource and returns the
// inner handle as the exported rep verbatim.
//
// Both `import chain` and `export chain` reference the same named
// interface `test:resource-floats-opaque/chain`. The Component Model
// gives them distinct resource type identities (different ownership),
// but the names match directly during WAC composition — no aliasing
// layer needed.
world intermediate {
  import chain;
  export chain;
}

world runner {
  import chain;

  export run: func();
}
